{
  "uid": "egzamin-main",
  "title": "Egzamin Maklerski",
  "tags": ["egzamin"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Questions in Database",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [
        { "datasource": "Prometheus", "expr": "exam_questions_total", "legendFormat": "Questions", "instant": true }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 2,
      "title": "Registered Users",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "targets": [
        { "datasource": "Prometheus", "expr": "exam_users_total", "legendFormat": "Users", "instant": true }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 3,
      "title": "Logins in Last 24h",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }
        }
      },
      "targets": [
        { "datasource": "Prometheus", "expr": "exam_logins_today", "legendFormat": "Logins 24h", "instant": true }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 4,
      "title": "Total Google Logins",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }
        }
      },
      "targets": [
        { "datasource": "Prometheus", "expr": "exam_google_logins_total", "legendFormat": "Google logins", "instant": true }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 5,
      "title": "Total Guest Logins",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        }
      },
      "targets": [
        { "datasource": "Prometheus", "expr": "exam_guest_logins_total", "legendFormat": "Guest logins", "instant": true }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 6,
      "title": "HTTP Requests / Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 }, "unit": "reqps" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total[1m])) by (handler)",
          "legendFormat": "{{handler}}"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 7,
      "title": "Response Time (Percentiles)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 }, "unit": "s" }
      },
      "targets": [
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, handler))", "legendFormat": "p50 {{handler}}" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, handler))", "legendFormat": "p95 {{handler}}" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, handler))", "legendFormat": "p99 {{handler}}" }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 8,
      "title": "HTTP Responses by Status Code",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 }, "unit": "reqps" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total[1m])) by (status)",
          "legendFormat": "HTTP {{status}}"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 9,
      "title": "Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ]}
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total{status=~\"4..|5..\"}[5m])) / sum(rate(http_requests_total[5m]))",
          "legendFormat": "Error %"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 10,
      "title": "Logins Over Time (Google vs Guest)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 }, "unit": "short" }
      },
      "targets": [
        { "datasource": "Prometheus", "expr": "exam_google_logins_total", "legendFormat": "Google logins" },
        { "datasource": "Prometheus", "expr": "exam_guest_logins_total", "legendFormat": "Guest logins" }
      ],
      "datasource": "Prometheus"
    }
  ]
}
